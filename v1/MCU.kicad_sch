	(text_box "We will run BMI270 at 50Hz so the 10k pull ups are good enough, it will help in lengthening the batterry life instead of using 4.7k. I2C rise time spec = 1k ns. I2C speed = 120khz. Read time = 50ms"
		(exclude_from_sim no)
		(at 259.08 90.17 0)
		(size 22.86 24.13)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
