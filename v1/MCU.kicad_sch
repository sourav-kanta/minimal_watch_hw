			)
			(justify left top)
		)
		(uuid "352aca04-02bb-4495-8d8c-336783231b8a")
	)
	(text_box "The ST7735s is rated for 15mHz so no need to use dedicated IOMUX pins, we can comfortable run the display at 40mHz or even stoop down to 26mHz for a refresh rate of aprrox 50fps\n"
		(exclude_from_sim no)
		(at 88.9 186.69 0)
		(size 49.53 10.16)
		(margins 0.9525 0.9525 0.9525 0.9525)
